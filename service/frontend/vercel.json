{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --no-audit --no-fund",
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist/ecommerce-frontend/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://e-commerce-9dql3r3pa-miguel-hernandezs-projects-b6076a4e.vercel.app/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
